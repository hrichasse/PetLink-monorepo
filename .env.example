# ─────────────────────────────────────────────
# PetLink Monorepo — Variables de Entorno
# Copia este archivo como .env y completa los valores.
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# URL pública del proyecto Supabase (aparece en Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co

# Clave anónima pública de Supabase (safe para exponer en el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Clave de Service Role (NUNCA exponer en el frontend)
# Usada en: packages/shared/src/lib/supabase.ts (supabaseAdminClient)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Base de Datos (Prisma) ─────────────────────
# URL de conexión via connection pooler de Supabase (puerto 6543)
# Usada en: packages/database/prisma/schema.prisma (url)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# URL directa sin pooler para migraciones Prisma (puerto 5432)
# Usada en: packages/database/prisma/schema.prisma (directUrl)
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Frontend (apps/web) ────────────────────────
# URLs de las APIs internas — ajustar según entorno
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_PETS_API_URL=http://localhost:3002/api/v1
NEXT_PUBLIC_MARKETPLACE_API_URL=http://localhost:3003/api/v1

# ── Comunicación interna entre apps (server-side) ─
# URL interna de la pets API usada por marketplace para validar ownership
# En Vercel: reemplazar con la URL pública del deploy de apps/pets
PETS_API_INTERNAL_URL=http://localhost:3002/api/v1

# ── Transbank (apps/marketplace) ───────────────
# development = ambiente integración (testing)
# production = ambiente real (cobros reales)
TRANSBANK_ENV=development

# En desarrollo puedes usar credenciales de integración oficiales.
# En producción reemplaza ambos valores por tus credenciales reales de Transbank.
TRANSBANK_COMMERCE_CODE=597055555532
TRANSBANK_API_KEY=579B532A7440BB0C9079DED94D31EA1615BACEB56610332264630D42D0A36B1C

# ── Asistente IA (apps/marketplace) ────────────
# Proveedor: Groq (free tier, sin tarjeta). Consíguela en https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Opcional: modelo a usar (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
